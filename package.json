{
  "name": "cmsv01-banking-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-surface banking platform with corporate web, bank ops web, unified BFF, core backend, and workers",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:bank-ops-web": "npm run build --workspace bank-ops-web",
    "build:bff": "tsc -b apps/bff --pretty false",
    "build:corporate-web": "npm run build --workspace corporate-web",
    "db:migrate": "node --dns-result-order=ipv4first --env-file=.env --import tsx scripts/db/migrate.ts",
    "db:seed": "node --dns-result-order=ipv4first --env-file=.env --import tsx scripts/db/seed.ts",
    "dev": "node scripts/dev/start-all.cjs",
    "dev:all": "node scripts/dev/start-all.cjs",
    "dev:api": "node scripts/dev/run-service.cjs api",
    "dev:bank-ops-web": "node scripts/dev/run-service.cjs bank-ops-web",
    "dev:bff": "node scripts/dev/run-service.cjs bff",
    "dev:corporate-web": "node scripts/dev/run-service.cjs corporate-web",
    "dev:worker": "node scripts/dev/run-service.cjs worker",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "kafkajs": "^2.2.4",
    "pg": "^8.20.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
